extern void func_02055388(int *m);
extern void func_0204c24c(u8 a, u8 b);

void func_0204b81c(Self *self, Node *node)
{
    Vec3 vecC;
    Vec3 posbuf;
    Vec3 vecA;
    Vec3 vecB;
    int matcopy[9];
    int mat[12];
    Ctx *c = self->p34;
    int q = c->p18->p0->q20;
    int scale = (node->p40.lo * (node->p40.hi + 1)) >> 5;
    int *m = self->p38;
    u32 v;
    u32 f2;
    int v1;
    s64 v1x;
    int v2;

    v = *(u32 *)((char *)c + 0x74) << 14;
    f2 = v >> 26;
    v = self->p30 | 0xc0;
    v |= f2 << 24;
    v |= (u32)scale << 16;
    *(volatile u32 *)0x40004a4 = v;
    *(volatile u32 *)0x40004a4;
    {
        Cnt74 *qc = (Cnt74 *)(u32)(((s64)(int)((char *)c + 0x74)) & 0xFFFFFFFFFFFFFFFFLL);
        qc->count++;
        if (c->cnt.count > c->cnt.limit)
            qc->count = c->cnt.start;
    }

    if (scale == 0)
        return;

    v1 = (int)(((s64)node->p30 * node->p34 + 0x800) >> 12);
    posbuf.x = node->p14 + node->p8;
    posbuf.y = node->p18 + node->pc;
    vecA = node->p20;
    v1x = v1;
    posbuf.z = node->p1c + node->p10;
    v2 = (int)(((s64)v1 * q + 0x800) >> 12);
    vecB.x = m[2];
    vecB.y = m[5];
    vecB.z = m[8];
    CrossVec3(&vecA, &vecB, &vecA);

    if (vecA.x == 0 && vecA.y == 0 && vecA.z == 0)
        return;

    NormalizeVec3(&vecA, &vecA);
    Copy36Bytes(m, matcopy);
    MulVec3Mat3x3(&vecA, matcopy, &vecA);
    MulVec3Mat4x3(&posbuf, m, &posbuf);
    vecC = node->p20;
    NormalizeVec3(&vecC, &vecC);

