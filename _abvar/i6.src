        int tz = (int)(((s64)vecC.z * -m[8] + 0x800) >> 12);
        int tx = (int)(((s64)vecC.x * -m[2] + 0x800) >> 12);
        int ty = (int)(((s64)vecC.y * -m[5] + 0x800) >> 12);
